# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar (optional, for meeting notifications)
# GOOGLE_CREDENTIALS_PATH=~/.config/fresnel/credentials.json

# Hue Bridge credentials are managed by Fresnel itself.
# Run `fresnel setup` to pair with your bridge.
# Config is stored in ~/.config/fresnel/hue.json
